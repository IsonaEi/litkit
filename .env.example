# litkit example environment file.
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# These are read directly from the environment by the scripts; `litkit` does not
# parse `.env` itself, so `source .env` (or use a tool like direnv) before running.

# ─── discover (Stage 1) ──────────────────────────────────────────────────────
# Required by the NCBI Entrez (PubMed) API — use a real contact email.
ENTREZ_EMAIL=you@example.com

# Optional. Raises Semantic Scholar rate limits. Shared with the manage tool.
# S2_API_KEY=

# Optional. Path to your search config (defaults to the bundled example).
# LITKIT_CONFIG=/path/to/your/search-config.json

# Optional. Output directory for `--cron` runs (default: /tmp/litkit-discover).
# LITKIT_OUTPUT=/path/to/scout-output

# Optional. Directory of .md notes used for Stage-2 corpus-affinity re-ranking.
# Leave unset to skip corpus re-ranking (BM25-only).
# LITKIT_CORPUS_DIR=/path/to/your/notes

# Optional. A shell command to fire when a cron digest is ready. The summary
# text is appended as a final argument. Unset = no notification.
# LITKIT_NOTIFY_CMD=notify-send 'Literature Scout'

# ─── manage (Stage 2) ────────────────────────────────────────────────────────
# Opt-in only. Set to 1 to allow the Sci-Hub download fallback. OFF by default.
# You are responsible for legal/ethical compliance. Default sources (publisher,
# EuropePMC, arXiv) are always tried first.
# LITKIT_ENABLE_SCIHUB=0

# ─── search (Stage 3) ────────────────────────────────────────────────────────
# Required. Directory of PDF/MD papers to index.
# LIT_QUERY_CORPUS=/path/to/your/library

# Optional. Extra corpus directories, comma-separated.
# LIT_QUERY_CORPUS_EXTRA=/path/to/more/markdown,/path/to/even/more

# Optional. Qdrant on-disk storage location (default: ~/.lit-query/qdrant_storage).
# LIT_QUERY_DB=/path/to/qdrant_storage

# Optional. Qdrant collection name (default: literature).
# LIT_QUERY_COLLECTION=literature

# Optional. HuggingFace embedding model (default: BAAI/bge-m3).
# LIT_QUERY_EMBEDDING_MODEL=BAAI/bge-m3

# Optional. Max tokens per chunk (default: 512).
# LIT_QUERY_CHUNK_MAX_TOKENS=512
